{
  "version": 1,
  "updated_by": "david",
  "updated_at": "2026-03-22",
  "notes": "Initial pre-filter rules for Enricher Stage 0. Houston Command can update these.",
  "required_fields": {
    "entity_name": true,
    "at_least_one_of": ["address", "state", "entity_number"]
  },
  "junk_entity_patterns": [
    "DISSOLVED", "CANCELLED", "INACTIVE", "REVOKED", "FORFEITED", "SUSPENDED",
    "CT CORPORATION", "CSC", "INCORP SERVICES", "NATIONAL REGISTERED AGENTS",
    "CORPORATION SERVICE", "LEGALINC", "NORTHWEST REGISTERED", "COGENCY GLOBAL",
    "REGISTERED AGENT SOLUTIONS", "UNITED AGENT GROUP"
  ],
  "valid_property_types": [
    "Industrial", "Office", "Retail", "Multifamily", "Mixed-Use", "Commercial Land",
    "Flex", "Warehouse", "Distribution", "Manufacturing", "R&D", "Cold Storage"
  ],
  "skip_property_types": [
    "Residential", "Single Family", "Government", "Religious", "Agricultural",
    "Parking", "Self Storage", "Mobile Home"
  ],
  "target_geographies": {
    "primary_cities": [
      "Ontario", "Fontana", "Rancho Cucamonga", "Riverside", "San Bernardino",
      "Corona", "Eastvale", "Chino", "Chino Hills", "Pomona", "Jurupa Valley",
      "Perris", "Moreno Valley", "Redlands", "Highland", "Colton", "Rialto",
      "Upland", "Montclair", "Mira Loma", "Bloomington", "Loma Linda",
      "Grand Terrace", "Norco", "Lake Elsinore", "Menifee", "Temecula",
      "Beaumont", "Banning", "Hemet", "San Jacinto"
    ],
    "primary_counties": ["San Bernardino County", "Riverside County"],
    "secondary_counties": ["Los Angeles County", "Orange County"],
    "skip_if_outside_all": true
  },
  "duplicate_detection": {
    "freshness_days": 90,
    "match_fields": ["full_name", "email", "phone_1"]
  },
  "confidence_thresholds": {
    "minimum_to_submit": 40,
    "minimum_sources_if_below_65": 2,
    "auto_skip_below": 20
  }
}
