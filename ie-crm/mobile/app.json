{
  "expo": {
    "name": "Houston",
    "slug": "houston-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "houston",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iecrm.houston",
      "infoPlist": {
        "NSCameraUsageDescription": "Houston needs camera access to take photos of properties",
        "NSPhotoLibraryUsageDescription": "Houston needs photo library access to send images",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "package": "com.iecrm.houston"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Houston needs photo library access to send images",
          "cameraPermission": "Houston needs camera access to take photos of properties"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
