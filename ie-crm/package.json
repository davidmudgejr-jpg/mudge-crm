{
  "name": "ie-crm",
  "version": "1.0.0",
  "description": "IE CRM — Commercial Real Estate CRM for the Inland Empire",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "node scripts/wait-for-port.js 5173 127.0.0.1 60 && electron .",
    "dev:web": "concurrently \"npm run dev:react\" \"npm run dev:server\"",
    "dev:server": "node server/index.js",
    "prestart": "node scripts/check-duplicate-filenames.js",
    "prebuild": "node scripts/check-duplicate-filenames.js",
    "prebuild:web": "node scripts/check-duplicate-filenames.js",
    "build": "vite build && electron-builder",
    "build:web": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "audit:schema-columns": "node scripts/audit-schema-columns.js",
    "suggested-updates:apply": "node scripts/apply-suggested-updates.js",
    "migrate": "node scripts/migrate.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20 <27"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@e965/xlsx": "^0.20.3",
    "@elevenlabs/elevenlabs-js": "^2.39.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cytoscape": "^3.33.2",
    "cytoscape-cola": "^2.5.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.15",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.iecrm.app",
    "productName": "IE CRM",
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "target": "dmg",
      "identity": null
    },
    "dmg": {
      "title": "IE CRM",
      "icon": "build/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/@vitejs/**",
      "!node_modules/vite/**",
      "!node_modules/tailwindcss/**",
      "!node_modules/autoprefixer/**",
      "!node_modules/postcss/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/concurrently/**"
    ],
    "asar": true
  }
}
