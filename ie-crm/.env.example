# IE CRM — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL Database (Railway or local)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your-password@your-host.railway.app:5432/railway

# Anthropic API Key (for Claude AI assistant)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Airtable API Key (for data sync)
# Get yours at https://airtable.com/create/tokens
AIRTABLE_API_KEY=pat-your-key-here

# Airtable Base ID (the base to sync from)
# Find it in your Airtable base URL: https://airtable.com/appXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appQaZNM0Mt4Zul3q
